{
  "name": "@collabswarm/collabswarm-react",
  "description": "React hooks for collabswarm documents",
  "version": "0.1.0",
  "scripts": {
    "tsc": "tsc -b",
    "prepublishOnly": "yarn tsc",
    "test": "jest",
    "tsc-watch": "tsc -w -p tsconfig.json"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": "./dist/src/index.js"
  },
  "files": [
    "dist"
  ],
  "author": "allegrormc@gmail.com",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@peculiar/webcrypto": "^1.4.6",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.11",
    "eslint": "^10.0.2",
    "jest": "^29.2.5",
    "jest-environment-jsdom": "^30.3.0",
    "react-dom": "^18.3.1",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@collabswarm/collabswarm": "workspace:packages/collabswarm",
    "react": "^18.3.1"
  },
  "gitHead": "5d48e475ac53ef5920423d3a22a4e19201e607a1",
  "publishConfig": {
    "access": "public"
  },
  "jest": {
    "roots": [
      "<rootDir>/src"
    ],
    "testEnvironment": "jsdom",
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {}
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/"
    ],
    "setupFiles": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@chainsafe/(.*)$": "<rootDir>/jest.empty-mock.js",
      "^@libp2p/(.*)$": "<rootDir>/jest.empty-mock.js",
      "^@helia/(.*)$": "<rootDir>/jest.empty-mock.js",
      "^helia$": "<rootDir>/jest.empty-mock.js",
      "^libp2p$": "<rootDir>/jest.empty-mock.js",
      "^ipns/(.*)$": "<rootDir>/jest.empty-mock.js",
      "^datastore-idb$": "<rootDir>/jest.empty-mock.js",
      "^blockstore-idb$": "<rootDir>/jest.empty-mock.js",
      "^it-pipe$": "<rootDir>/jest.empty-mock.js",
      "^bl$": "<rootDir>/jest.empty-mock.js",
      "^multiformats$": "<rootDir>/jest.empty-mock.js",
      "^@multiformats/multiaddr$": "<rootDir>/jest.empty-mock.js",
      "^uint8arraylist$": "<rootDir>/jest.empty-mock.js"
    }
  }
}
