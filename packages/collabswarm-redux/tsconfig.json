{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ESNext", "DOM"],
    "sourceMap": true,
    "downlevelIteration": true,
    "strict": true,
    "declaration": true,
    "typeRoots": ["types", "node_modules/@types"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "outDir": "dist",
    "composite": true
  },
  "exclude": [
    "node_modules",
    "examples",
    "src/**/*.test.ts"
  ],
  "include": [
    "src",
    "types",
    "bin"
  ],
  "references": [
    {
      "path": "../collabswarm",
    }
  ]
}
