{
  "compilerOptions": {
    "target": "es2022",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "esnext",
    "moduleResolution": "node",
    "types": ["vite/client"],
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react"
  },
  "include": [
    "src"
  ],
  "exclude": ["src/relay.ts", "src/serviceWorker.ts"],
  "references": [
    {
      "path": "../../packages/collabswarm"
    },
    {
      "path": "../../packages/collabswarm-automerge"
    },
    {
      "path": "../../packages/collabswarm-redux"
    }
  ]
}
